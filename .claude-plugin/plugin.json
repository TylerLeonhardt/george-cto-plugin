{
	"name": "george-cto-plugin",
	"version": "0.1.0",
	"description": "CTO-in-a-plugin — dispatch autonomous Team Lead agents with development culture built in",
	"author": {
		"name": "TylerLeonhardt"
	},
	"license": "MIT",
	"homepage": "https://github.com/TylerLeonhardt/george-cto-plugin",
	"repository": "https://github.com/TylerLeonhardt/george-cto-plugin",
	"keywords": ["cto", "team-lead", "quality", "development-culture", "autonomous-agents"],
	"agents": ["./agents/team-lead/team-lead.agent.md"],
	"skills": "./skills/",
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-lint.sh",
						"timeout": 30
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-end-tests.sh",
						"timeout": 300
					}
				]
			}
		]
	}
}
